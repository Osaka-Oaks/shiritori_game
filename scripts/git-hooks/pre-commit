#!/bin/bash
# Pre-commit hook - validates commits before they're created
# Install: ln -s ../../scripts/git-hooks/pre-commit .git/hooks/pre-commit

set -e

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

echo -e "${BLUE}в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ${NC}"
echo -e "${BLUE}рџ”Ќ Pre-Commit Validation${NC}"
echo -e "${BLUE}в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ${NC}"
echo ""

# Get staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

if [ -z "$STAGED_FILES" ]; then
  echo -e "${YELLOW}вљ пёЏ  No files staged${NC}"
  exit 0
fi

echo -e "${BLUE}Files to commit: $(echo "$STAGED_FILES" | wc -l | tr -d ' ')${NC}"
echo ""

# Check 1: Validate JSON files
echo -e "${YELLOW}[1/5] Validating JSON files...${NC}"
JSON_FILES=$(echo "$STAGED_FILES" | grep '\.json$' || true)
if [ -n "$JSON_FILES" ]; then
  for file in $JSON_FILES; do
    if ! python3 -m json.tool "$file" > /dev/null 2>&1; then
      echo -e "${RED}вќЊ Invalid JSON: $file${NC}"
      exit 1
    fi
  done
  echo -e "${GREEN}вњ… All JSON files valid${NC}"
else
  echo -e "${BLUE}в„№пёЏ  No JSON files to validate${NC}"
fi

# Check 2: Lint staged files
echo -e "${YELLOW}[2/5] Linting code...${NC}"
TS_FILES=$(echo "$STAGED_FILES" | grep -E '\.(ts|tsx)$' || true)
if [ -n "$TS_FILES" ]; then
  # Run ESLint only on staged files
  if command -v npx &> /dev/null; then
    echo "$TS_FILES" | xargs npx eslint --quiet || {
      echo -e "${RED}вќЊ ESLint errors found${NC}"
      echo -e "${YELLOW}Fix with: npm run lint:fix${NC}"
      exit 1
    }
    echo -e "${GREEN}вњ… Linting passed${NC}"
  fi
else
  echo -e "${BLUE}в„№пёЏ  No TypeScript files to lint${NC}"
fi

# Check 3: Format check
echo -e "${YELLOW}[3/5] Checking formatting...${NC}"
if command -v npx &> /dev/null; then
  if ! echo "$STAGED_FILES" | xargs npx prettier --check --loglevel=error; then
    echo -e "${RED}вќЊ Formatting issues found${NC}"
    echo -e "${YELLOW}Fix with: npm run format${NC}"
    exit 1
  fi
  echo -e "${GREEN}вњ… Formatting correct${NC}"
fi

# Check 4: Check for sensitive data
echo -e "${YELLOW}[4/5] Checking for sensitive data...${NC}"
SECRETS_FOUND=false

for file in $STAGED_FILES; do
  # Check for common secret patterns
  if grep -qE '(AIza[0-9A-Za-z_-]{35}|sk_live_[0-9a-zA-Z]{24}|AKIA[0-9A-Z]{16})' "$file" 2>/dev/null; then
    echo -e "${RED}вќЊ Potential API key found in: $file${NC}"
    SECRETS_FOUND=true
  fi
  
  # Check for .env files
  if echo "$file" | grep -qE '\.(env|env\.local|env\.production)$'; then
    echo -e "${RED}вќЊ Environment file detected: $file${NC}"
    SECRETS_FOUND=true
  fi
done

if [ "$SECRETS_FOUND" = true ]; then
  echo -e "${RED}вќЊ Sensitive data detected${NC}"
  exit 1
fi
echo -e "${GREEN}вњ… No sensitive data found${NC}"

# Check 5: Commit message format (in commit-msg hook)
echo -e "${YELLOW}[5/5] Ready for commit${NC}"

# Summary
echo ""
echo -e "${BLUE}в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ${NC}"
echo -e "${GREEN}вњ… Pre-commit checks passed!${NC}"
echo -e "${BLUE}в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ${NC}"
echo ""

# Show files being committed
echo -e "${BLUE}Files staged for commit:${NC}"
echo "$STAGED_FILES" | sed 's/^/  /'
echo ""
