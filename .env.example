# =============================================================================
# Shiritori monorepo — environment variables (copy to .env, never commit .env)
# Project: shiritori-game-ccaae
# Get Firebase values: Firebase Console → Project settings → Your apps → Web app
# =============================================================================

# --- Firebase web client (Vite apps: shiritori-online, kawaii-shiritori, shiritori-word-chain)
# Client keys are not secret; access is enforced by Firebase security rules.
# Use GitHub Actions secrets OR repository variables for CI builds.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=shiritori-game-ccaae.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://shiritori-game-ccaae-default-rtdb.firebaseio.com
VITE_FIREBASE_PROJECT_ID=shiritori-game-ccaae
VITE_FIREBASE_STORAGE_BUCKET=shiritori-game-ccaae.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
VITE_FIREBASE_FIRESTORE_DATABASE_ID=(default)

# --- Server-only (Express dev servers — kawaii-shiritori, shiritori-word-chain)
# NEVER expose in client bundle. Add as GitHub Actions SECRETS only.
GEMINI_API_KEY=

# Optional local AI (kawaii-shiritori)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen3
VITE_AI_PROVIDER=gemini

# --- CI/CD deploy (GitHub Actions secrets — not used in local .env unless deploying manually)
# FIREBASE_TOKEN=          # firebase login:ci — deploy hosting/rules
# FIREBASE_SERVICE_ACCOUNT=  # JSON for FirebaseExtended/action-hosting-deploy (optional)

# --- Observability (optional — uptime / metrics workflows)
# DATADOG_API_KEY=
# DATADOG_SITE=datadoghq.com
# GRAFANA_CLOUD_API_KEY=
# GRAFANA_CLOUD_STACK_URL=
# GRAFANA_CLOUD_METRICS_URL=
# GRAFANA_CLOUD_INSTANCE_ID=
# ELASTICSEARCH_URL=
