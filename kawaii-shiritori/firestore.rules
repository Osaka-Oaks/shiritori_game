rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Reusable global helper gates
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 3. Validation Blueprint for User Profiles & Customizations
    function isValidUser(data) {
      return data.uid is string && data.uid.size() <= 128 &&
             data.name is string && data.name.size() <= 100 &&
             data.avatarUrl is string && data.avatarUrl.size() <= 1000 &&
             data.accentColor is string && data.accentColor.size() <= 50 &&
             (!('gridStyle' in data) || (data.gridStyle is string && data.gridStyle.size() <= 50)) &&
             (!('font' in data) || (data.font is string && data.font.size() <= 100)) &&
             (!('headingStyle' in data) || (data.headingStyle is string && data.headingStyle.size() <= 50)) &&
             (!('layoutDensity' in data) || (data.layoutDensity is string && data.layoutDensity.size() <= 50));
    }

    // 4. Users Collection Rules (PII Isolation and ID poisoning guard)
    match /users/{userId} {
      allow get: if isOwner(userId) && isValidId(userId);
      allow create: if isOwner(userId) && isValidId(userId) && isValidUser(incoming()) && incoming().uid == userId;
      allow update: if isOwner(userId) && isValidId(userId) && isValidUser(incoming()) && incoming().uid == existing().uid;
      allow delete: if isOwner(userId) && isValidId(userId);
    }

    // 5. Leaderboard — public read, owner write (Spark-friendly scores)
    match /leaderboard/{userId} {
      allow read: if true;
      allow create, update: if isOwner(userId) && isValidId(userId);
      allow delete: if isOwner(userId) && isValidId(userId);
    }

    // 6. Two-Player Game Rooms (Real-time multiplayer)
    match /games/{gameId} {
      // Anyone signed in can read games
      allow read: if isSignedIn();
      
      // Only host can create a game
      allow create: if isSignedIn() && 
                       incoming().hostUid == request.auth.uid &&
                       incoming().status == 'waiting';
      
      // Players in the game can update
      allow update: if isSignedIn() && (
        existing().hostUid == request.auth.uid ||
        existing().guestUid == request.auth.uid ||
        // Allow joining if guest slot is empty
        (!('guestUid' in existing()) && incoming().guestUid == request.auth.uid)
      );
      
      // Only host can delete
      allow delete: if isSignedIn() && existing().hostUid == request.auth.uid;
    }
    
    // 7. Game Moves (Append-only word history)
    match /games/{gameId}/moves/{moveId} {
      allow read: if isSignedIn();
      
      // Can only create moves, not update/delete (append-only)
      allow create: if isSignedIn() &&
                       incoming().playerId == request.auth.uid &&
                       incoming().timestamp == request.time;
      
      allow update, delete: if false; // Moves are immutable
    }
    
    // 8. Game Stats & History (Personal performance tracking)
    match /gameHistory/{userId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }
    
    // 9. Active Rooms List (For matchmaking)
    match /activeRooms/{roomId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && incoming().hostUid == request.auth.uid;
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }
    
    // 10. Player Presence (Online/Offline status)
    match /presence/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }
  }
}
