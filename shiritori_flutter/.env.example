# Flutter environment variables (optional for runtime configuration)
# Firebase config is in lib/firebase_options.dart (generated by FlutterFire CLI)

# =============================================================================
# Firebase Configuration
# =============================================================================
# Flutter uses firebase_options.dart which is generated by:
#   flutterfire configure --project=shiritori-game-ccaae
#
# Platform-specific config files:
#   Android: android/app/google-services.json (generated by FlutterFire)
#   iOS: ios/Runner/GoogleService-Info.plist (generated by FlutterFire)
#   Web/macOS: lib/firebase_options.dart (generated by FlutterFire)
#
# These files contain Firebase client API keys which are safe to commit
# (access control is via Firebase Security Rules, not API key secrecy)

# =============================================================================
# Build Configuration (optional)
# =============================================================================
# Uncomment if you need build-time environment switching
# FLUTTER_ENV=production
# FLUTTER_DEFINE_APP_NAME=Shiritori Game
# FLUTTER_DEFINE_API_URL=https://api.example.com

# =============================================================================
# Development Settings (optional)
# =============================================================================
# For local development with emulators
# FIREBASE_USE_EMULATOR=true
# FIREBASE_EMULATOR_HOST=localhost
# FIREBASE_AUTH_EMULATOR_PORT=9099
# FIREBASE_FIRESTORE_EMULATOR_PORT=8080
# FIREBASE_DATABASE_EMULATOR_PORT=9000
# FIREBASE_STORAGE_EMULATOR_PORT=9199

# =============================================================================
# Notes
# =============================================================================
# 1. This file is primarily for documentation purposes
# 2. Flutter reads firebase_options.dart at compile time (not .env)
# 3. For runtime config, use --dart-define flags:
#    flutter run --dart-define=ENV=staging
# 4. Firebase CLI token for deploy: stored in CI as FIREBASE_TOKEN secret
# 5. To regenerate Firebase config: flutterfire configure
