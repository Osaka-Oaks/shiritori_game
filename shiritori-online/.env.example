# OPTIONAL. The Firebase web config is already baked into src/firebase.ts for your
# "shiritori-game-ccaae" project, so the app runs without this file.
#
# If you'd rather keep config out of source (e.g. to reuse the code for another
# project), copy this file to ".env" and fill it in — src/firebase.ts will prefer
# these values when present. Client Firebase keys are safe to expose; security is
# enforced by the Realtime Database rules in database.rules.json.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
